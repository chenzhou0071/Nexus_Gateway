# Nexus-Gateway 配置示例

[server]
listen       = 0.0.0.0:8080
worker_num   = auto
log_level    = info
max_conns    = 10000

[upstream.api]
# 加权轮询后端，weight 缺省 = 1
server  = 127.0.0.1:9001 weight=3
server  = 127.0.0.1:9002 weight=2
server  = 127.0.0.1:9003 weight=1

[upstream.static]
type    = file
root    = /var/www/html

[route]
# 路径前缀 → 上游名
/api    = api
/static = static

[security]
rate_limit_per_ip = 100
blacklist         = 192.168.1.100, 10.0.0.5

[http_rewrite]
# 自定义头部：key:value 格式
#如add_header = X-Custom-Trace:my-app-1.0